# ============================================================
# Deep Dive — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# ============================================================

# ------ Required ------
FIREWORKS_API_KEY=your-fireworks-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# ------ Fireworks Config (defaults shown) ------
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/qwen2p5-72b-instruct

# ------ AMD Developer Cloud (optional, for Synthesis Agent) ------
# Set SYNTHESIS_MODEL_PROVIDER=amd_cloud to route the Synthesis Agent
# through a self-hosted vLLM endpoint on an AMD MI300X instance.
SYNTHESIS_MODEL_PROVIDER=fireworks
AMD_CLOUD_BASE_URL=http://your-mi300x-endpoint:8000/v1
AMD_CLOUD_API_KEY=your-amd-cloud-api-key
AMD_CLOUD_MODEL=your-model-name
